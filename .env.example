

# MariaDB 연결 문자열
DATABASE_URL="mysql://app_user:app_pass@127.0.0.1:3306/app_db"
# Prisma Migrate용 그림자 데이터베이스 연결 문자열
SHADOW_DATABASE_URL="mysql://app_user:app_pass@127.0.0.1:3306/app_db_shadow"

# MariaDB 연결 설정(연결 문자열을 분해하기)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=app_user
DATABASE_PASSWORD=app_pass
DATABASE_NAME=app_db
DATABASE_SHADOW_NAME=app_db_shadow

# JWT 시크릿 키 (보안을 위해 실제 배포에서는 강력한 키로 변경하세요)
JWT_SECRET="your_jwt_secret_key"

# 비바톤 사이트에서 클라이언트를 생성하여 CLIENT_ID와 SECRET_KEY를 메일로 전송받으세요.
# 리다이렉트 URI는 .../bbaton/redirectUrl 로 등록해야 합니다.
BBATON_CLIENT_ID=
BBATON_REDIRECT_URI=http://localhost:3000/bbaton/redirectUrl
BBATON_SECRET_KEY=

# 사이트 도메인 적어주면 됩니다.
PICS_LABEL_ADDRESS=http://localhost:3000

# ── 이메일 인증 메일(SMTP) ───────────────────────────────────────────────
# 이메일 인증 링크에 사용되는 기본 URL입니다. 배포 시 실제 도메인으로 변경하세요.
NEXT_PUBLIC_BASE_URL=http://localhost:3000 
# SMTP 설정입니다. Gmail SMTP를 예시로 들었지만, 다른 SMTP 서비스도 사용할 수 있습니다.
SMTP_HOST=smtp.gmail.com
# SMTP 포트는 보통 465(SSL) 또는 587(TLS)입니다. 사용하는 SMTP 서비스에 맞게 설정하세요.
SMTP_PORT=465
# SMTP_SECURE는 SSL/TLS 사용 여부입니다. 465 포트는 true, 587 포트는 false로 설정하는 경우가 많습니다.
SMTP_SECURE=true
# SMTP_USER와 SMTP_PASS는 실제 이메일 계정과 비밀번호로 설정해야 합니다. 보안을 위해 환경 변수로 관리하세요.
SMTP_USER=
# SMTP_PASS는 실제 비밀번호가 아니라 2단계 인증 후 발급받은 앱 비밀번호로 해야합니다.
SMTP_PASS=
# SMTP_FROM은 이메일 발신자 주소입니다. 실제로 존재하는 이메일 주소로 설정하는 것이 좋습니다.
SMTP_FROM=no-reply@moonshineland.local

# ── GCS 이미지 업로드 ─────────────────────────────────────────────────────
# GCS_BUCKET_NAME      버킷 이름 (필수)
# GCS_KEY_FILE         서비스 계정 JSON 경로 (생략 시 ADC/Workload Identity 사용)
# GCS_PROJECT_ID       GCP 프로젝트 ID (생략 가능)
# GCS_PUBLIC_URL_BASE  커스텀 도메인 (예: https://img.example.com); 생략 시 storage.googleapis.com 사용
GCS_BUCKET_NAME=test-moonshine-image
# GCS_KEY_FILE=/path/to/service-account.json
# GCS_PROJECT_ID=applied-light-271504
# GCS_PUBLIC_URL_BASE=https://storage.googleapis.com/your-bucket-name

# 관리자 계정 정보
# 개발 환경 중에만 필요합니다. 배포 시에는 시드 대신 마이그레이션을 씁니다.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"
ADMIN_USERNAME="admin"